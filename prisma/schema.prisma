generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id           String      @id @default(uuid())
  name         String
  code         String?     @unique
  logoUrl      String?
  academicYear Int
  semester     Int
  users        User[]
  classrooms   Classroom[]
  students     Student[]
  createdAt    DateTime    @default(now())
}

model User {
  id           String      @id @default(uuid())
  schoolId     String
  school       School      @relation(fields: [schoolId], references: [id])
  name         String
  email        String      @unique
  passwordHash String
  role         Role
  isActive     Boolean     @default(true)
  classrooms   Classroom[]
  createdAt    DateTime    @default(now())
}

model Classroom {
  id           String     @id @default(uuid())
  schoolId     String
  school       School     @relation(fields: [schoolId], references: [id])
  levelName    String
  roomName     String
  teacherId    String?
  teacher      User?      @relation(fields: [teacherId], references: [id])
  academicYear Int
  students     Student[]
  createdAt    DateTime   @default(now())
}

model Student {
  id             String             @id @default(uuid())
  schoolId       String
  school         School             @relation(fields: [schoolId], references: [id])
  classroomId    String
  classroom      Classroom          @relation(fields: [classroomId], references: [id])
  studentCode    String?
  numberInRoom   Int
  firstName      String
  lastName       String
  gender         Gender
  birthDate      DateTime
  guardianName   String?
  guardianPhone  String?
  isActive       Boolean            @default(true)
  attendance     AttendanceRecord[]
  milkRecords    MilkRecord[]
  dentalRecords  DentalRecord[]
  healthRecords  HealthRecord[]
  createdAt      DateTime           @default(now())
}

model AttendanceRecord {
  id          String           @id @default(uuid())
  studentId   String
  student     Student          @relation(fields: [studentId], references: [id])
  recordDate  DateTime
  status      AttendanceStatus
  note        String?
  recordedBy  String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([studentId, recordDate])
  @@index([recordDate, status])
}

model MilkRecord {
  id          String     @id @default(uuid())
  studentId   String
  student     Student    @relation(fields: [studentId], references: [id])
  recordDate  DateTime
  status      MilkStatus
  note        String?
  recordedBy  String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([studentId, recordDate])
}

model DentalRecord {
  id          String       @id @default(uuid())
  studentId   String
  student     Student      @relation(fields: [studentId], references: [id])
  recordDate  DateTime
  status      DentalStatus
  note        String?
  recordedBy  String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([studentId, recordDate])
}

model HealthRecord {
  id           String   @id @default(uuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  measuredDate DateTime
  weightKg     Decimal
  heightCm     Decimal
  bmi          Decimal
  bmiCategory  String
  note         String?
  recordedBy   String
  createdAt    DateTime @default(now())

  @@index([studentId, measuredDate])
}

enum Role {
  admin
  teacher
  executive
}

enum Gender {
  male
  female
  other
}

enum AttendanceStatus {
  present
  absent
  leave
  late
}

enum MilkStatus {
  drank
  not_drank
}

enum DentalStatus {
  brushed
  not_brushed
}
